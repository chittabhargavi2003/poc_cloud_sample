# GCP OAuth 2.0 credentials
# Copy this file to .env and fill in your actual values.
GCP_CLIENT_ID=your-client-id.apps.googleusercontent.com
GCP_CLIENT_SECRET=your-oauth-client-secret

# Optional: override backend/frontend base URLs used in OAuth redirect URIs
# GCP_OAUTH_BACKEND_BASE=http://localhost:8000
# GCP_OAUTH_FRONTEND_BASE=http://localhost:3000
